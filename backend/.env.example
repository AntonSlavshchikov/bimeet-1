PORT=8080
DSN=postgres://bimeet:bimeet@localhost:5432/bimeet?sslmode=disable
JWT_SECRET=change-me-in-production
JWT_EXP_HOURS=72
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=Bimeet <noreply@bimeet.local>
SMTP_USER=
SMTP_PASS=
FRONTEND_URL=http://localhost:5173
# S3-compatible storage (required for avatar uploads)
# For local dev with MinIO (docker-compose):
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=avatars
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_BASE_URL=http://localhost:9000/avatars
# For production with MinIO behind Traefik (s3.bimeet.pro):
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=<key>
# AWS_SECRET_ACCESS_KEY=<secret>
# S3_BUCKET=avatars
# S3_ENDPOINT=http://minio:9000
# S3_PUBLIC_BASE_URL=https://s3.bimeet.pro/avatars
# For production with AWS S3 (remove S3_ENDPOINT):
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=<key>
# AWS_SECRET_ACCESS_KEY=<secret>
# S3_BUCKET=<bucket>
# S3_ENDPOINT=
# S3_PUBLIC_BASE_URL=https://<bucket>.s3.<region>.amazonaws.com
