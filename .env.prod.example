# Backend
PORT=8080
DSN=postgres://bimeet:<password>@postgres:5432/bimeet?sslmode=disable
JWT_SECRET=<strong-random-secret>
JWT_EXP_HOURS=72
FRONTEND_URL=https://your-domain.com

# Email (recommended: Resend HTTP API — port 443, works on any hosting)
# Get API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxx
MAIL_FROM=Bimeet <noreply@bimeet.pro>     # domain must be verified in Resend
# For testing without domain verification: MAIL_FROM=onboarding@resend.dev

# Alternative: SMTP (only if outbound 587/465 is open on your VPS — many hosters block it)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_FROM=Bimeet <noreply@your-domain.com>
# SMTP_USER=apikey
# SMTP_PASS=<sendgrid-api-key>

# AWS S3 (production — no S3_ENDPOINT)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=<key>
AWS_SECRET_ACCESS_KEY=<secret>
S3_BUCKET=<bucket>
S3_PUBLIC_BASE_URL=https://<bucket>.s3.<region>.amazonaws.com

# MinIO (alternative to AWS S3 — comment out AWS block above and use this)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
# S3_BUCKET=avatars
# S3_ENDPOINT=http://minio:9000
# S3_PUBLIC_BASE_URL=https://your-domain.com/minio/avatars

# Landing (baked into the Docker image at build time via NEXT_PUBLIC_APP_URL secret)
# Set NEXT_PUBLIC_APP_URL in GitHub Actions secrets → points to the SPA URL (e.g. https://app.your-domain.com)

# Docker Compose (used by docker-compose.prod.yml)
POSTGRES_PASSWORD=<strong-password>
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=<strong-password>
GITHUB_REPOSITORY_OWNER=<your-github-username>